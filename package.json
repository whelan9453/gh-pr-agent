{
  "name": "gh-pr-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Review GitHub pull requests with local AI backends.",
  "type": "module",
  "bin": {
    "gh-pr-review": "./dist/src/cli.js"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "scripts": {
    "build":     "tsc -p tsconfig.json && vite build && mkdir -p dist/prompts && cp prompts/*.md dist/prompts/",
    "prepare":   "npm run build",
    "dev":       "tsx --watch src/server/dev-server.ts & vite --config vite.config.ts",
    "test":      "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p ui/tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@octokit/rest": "^22.0.0",
    "cli-highlight": "^2.1.11",
    "commander": "^14.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "node-fetch": "^3.3.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.3",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^27.0.0",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.10",
    "vitest": "^4.1.1"
  }
}
